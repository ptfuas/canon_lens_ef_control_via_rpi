{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Debug lens control",
            "type": "cppdbg",
            "request": "launch",
            "program": "${workspaceFolder}/lensctl",
            "args": ["init"],
            "stopAtEntry": false,
            "cwd": "${workspaceFolder}",
            "MIMode": "gdb",
            "miDebuggerPath": "/usr/bin/gdb",
            "externalConsole": false
        }
    ]
}